---
import Layout from "../layouts/Layout.astro";

const configJson = `{
  "profiles": [
    {
      "name": "mybot",
      "token": "123456:ABC-DEF",
      "chat_id": "999888777",
      "default": true
    },
    {
      "name": "work",
      "token": "456789:XYZ",
      "chat_id": "111222333"
    }
  ]
}`;
---

<Layout title="auto-message — Telegram notifications from the terminal">
  <!-- Hero ("The Overhang") -->
  <header class="pt-32 pb-24 px-8 relative overflow-hidden bg-surface-bright flex flex-col items-center text-center border-b border-surface-container-low">
    <div class="max-w-4xl mx-auto relative z-10">
      <h1 class="text-6xl md:text-8xl font-headline font-extrabold tracking-tighter text-on-surface mb-6 leading-none">
        auto-message
      </h1>
      <p class="text-xl md:text-2xl font-body text-on-surface-variant max-w-2xl mx-auto mb-12 font-light">
        Send Telegram bot notifications from terminal commands and automation scripts.
      </p>

      <!-- Hero Terminal -->
      <div class="bg-inverse-surface rounded-lg max-w-2xl mx-auto text-left shadow-[0px_24px_48px_rgba(45,52,53,0.15)] ring-1 ring-white/10 relative -mb-16 z-20">
        <div class="flex items-center justify-between px-4 py-3 border-b border-white/[0.06]">
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
            <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
            <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
          </div>
          <span class="text-xs font-mono text-on-surface-variant/40 tracking-wide">bash</span>
          <button class="flex items-center gap-1 text-on-surface-variant/40 hover:text-inverse-on-surface transition-colors cursor-pointer p-1 rounded hover:bg-white/[0.08]" title="Copy to clipboard" id="hero-copy-btn">
            <span class="material-symbols-outlined text-base">content_copy</span>
          </button>
        </div>
        <div class="px-6 py-5">
          <code class="font-mono text-base leading-relaxed break-all block">
            <span class="text-tertiary-fixed select-none">$ </span><span class="text-[#8b9cf7]">curl</span> <span class="text-on-surface-variant/70">-fsSL</span> <span class="text-inverse-on-surface">https://raw.githubusercontent.com/onurkerem/auto-message/main/install.sh</span> <span class="text-on-surface-variant/70">|</span> <span class="text-[#8b9cf7]">sh</span>
          </code>
        </div>
      </div>
    </div>

    <!-- Grid background -->
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-6xl h-full pointer-events-none opacity-[0.03]"
      style="background-image: linear-gradient(#2d3435 1px, transparent 1px), linear-gradient(90deg, #2d3435 1px, transparent 1px); background-size: 64px 64px;"
    >
    </div>
  </header>

  <!-- Features -->
  <section class="py-32 px-8 bg-surface-container-low mt-16" id="features">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-headline font-bold mb-16 text-center text-on-surface tracking-tight">
        Core Capabilities
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Named Profiles -->
        <div class="bg-surface-container-lowest p-8 border border-surface-container-highest transition-colors hover:border-outline-variant/30 group">
          <div class="w-12 h-12 bg-surface-container flex items-center justify-center rounded mb-6 text-on-surface group-hover:bg-primary group-hover:text-on-primary transition-colors">
            <span class="material-symbols-outlined">manage_accounts</span>
          </div>
          <h3 class="text-xl font-headline font-bold mb-3 text-on-surface">Named Profiles</h3>
          <p class="font-body text-on-surface-variant leading-relaxed">
            Configure multiple Telegram bots with names like <code class="font-mono text-sm bg-surface-container px-1.5 py-0.5">mybot</code>, <code class="font-mono text-sm bg-surface-container px-1.5 py-0.5">work</code>, or <code class="font-mono text-sm bg-surface-container px-1.5 py-0.5">prod</code>. Set one as default, or pick per command with <code class="font-mono text-sm bg-surface-container px-1.5 py-0.5">-c</code>.
          </p>
        </div>
        <!-- CI/CD Ready -->
        <div class="bg-surface-container-lowest p-8 border border-surface-container-highest transition-colors hover:border-outline-variant/30 group">
          <div class="w-12 h-12 bg-surface-container flex items-center justify-center rounded mb-6 text-on-surface group-hover:bg-primary group-hover:text-on-primary transition-colors">
            <span class="material-symbols-outlined">terminal</span>
          </div>
          <h3 class="text-xl font-headline font-bold mb-3 text-on-surface">CI/CD Ready</h3>
          <p class="font-body text-on-surface-variant leading-relaxed">
            Skip the config file entirely — set <code class="font-mono text-sm bg-surface-container px-1.5 py-0.5">AUTO_MESSAGE_TOKEN</code> and <code class="font-mono text-sm bg-surface-container px-1.5 py-0.5">AUTO_MESSAGE_CHAT_ID</code> as environment variables in any pipeline.
          </p>
        </div>
        <!-- Secure by Default -->
        <div class="bg-surface-container-lowest p-8 border border-surface-container-highest transition-colors hover:border-outline-variant/30 group">
          <div class="w-12 h-12 bg-surface-container flex items-center justify-center rounded mb-6 text-on-surface group-hover:bg-primary group-hover:text-on-primary transition-colors">
            <span class="material-symbols-outlined">security</span>
          </div>
          <h3 class="text-xl font-headline font-bold mb-3 text-on-surface">Secure by Default</h3>
          <p class="font-body text-on-surface-variant leading-relaxed">
            Bot tokens are never logged and masked in all output. Config files are written with restricted permissions. HTTPS only.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Usage -->
  <section class="py-32 px-8 bg-surface border-y border-surface-container-low" id="usage">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 items-center">
      <div class="w-full lg:w-1/2">
        <h2 class="text-3xl md:text-4xl font-headline font-bold mb-6 text-on-surface tracking-tight">Usage</h2>
        <p class="font-body text-lg text-on-surface-variant mb-8 leading-relaxed">
          Add a bot profile, then send messages from any terminal or script. The tool resolves credentials in order: explicit flag, default profile, environment variables.
        </p>
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-tertiary mt-1">check_circle</span>
            <p class="font-body text-on-surface-variant">One-command install and update via <code class="font-mono text-sm bg-surface-container px-1.5 py-0.5">curl | sh</code></p>
          </div>
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-tertiary mt-1">check_circle</span>
            <p class="font-body text-on-surface-variant">Cross-platform binaries for macOS, Linux, and Windows</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-tertiary mt-1">check_circle</span>
            <p class="font-body text-on-surface-variant">Config stored at <code class="font-mono text-sm bg-surface-container px-1.5 py-0.5">~/.config/auto-message/config.json</code></p>
          </div>
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-tertiary mt-1">check_circle</span>
            <p class="font-body text-on-surface-variant">Resolution order: <code class="font-mono text-sm bg-surface-container px-1.5 py-0.5">--config</code> flag &gt; default profile &gt; env vars</p>
          </div>
        </div>
      </div>
      <div class="w-full lg:w-1/2">
        <!-- Inline Terminal -->
        <div class="bg-inverse-surface rounded-lg p-6 text-left shadow-[0px_24px_48px_rgba(45,52,53,0.06)] ring-1 ring-white/10 w-full">
          <div class="flex items-center justify-between mb-4 border-b border-surface-variant/20 pb-2">
            <span class="text-xs font-mono text-on-surface-variant uppercase tracking-widest">Terminal</span>
          </div>
          <div class="font-mono text-sm space-y-4">
            <div>
              <span class="text-on-surface-variant opacity-70"># Add a bot profile</span><br />
              <span class="text-tertiary-fixed">$</span> <span class="text-[#8b9cf7]">auto-message</span> <span class="text-inverse-on-surface">config add mybot</span> <span class="text-on-surface-variant/70">--token "123456:ABC-DEF" --chat-id "999888777" --default</span>
            </div>
            <div>
              <span class="text-on-surface-variant opacity-70"># Send using default profile</span><br />
              <span class="text-tertiary-fixed">$</span> <span class="text-[#8b9cf7]">auto-message</span> <span class="text-inverse-on-surface">send "Build passed"</span>
            </div>
            <div>
              <span class="text-on-surface-variant opacity-70"># Send using specific profile</span><br />
              <span class="text-tertiary-fixed">$</span> <span class="text-[#8b9cf7]">auto-message</span> <span class="text-inverse-on-surface">send -c prod "Deployed to production"</span>
            </div>
            <div>
              <span class="text-on-surface-variant opacity-70"># List all profiles (tokens masked)</span><br />
              <span class="text-tertiary-fixed">$</span> <span class="text-[#8b9cf7]">auto-message</span> <span class="text-inverse-on-surface">config list</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Flow Diagram -->
  <section class="py-32 px-8 bg-surface-container-low" id="flow">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-headline font-bold mb-8 text-center text-on-surface tracking-tight">
        How It Works
      </h2>
      <p class="font-body text-lg text-on-surface-variant mb-16 text-center max-w-3xl mx-auto">
        Your terminal command goes through auto-message to the Telegram Bot API and arrives as a notification in your chat.
      </p>
      <div class="bg-surface-container-lowest p-12 border border-surface-container-highest flex flex-col md:flex-row gap-12 items-stretch">
        <!-- Input -->
        <div class="flex-1">
          <h4 class="font-headline font-bold text-on-surface mb-6 border-b border-surface-container-highest pb-2">Your Terminal</h4>
          <div class="space-y-3 font-mono text-sm text-on-surface-variant">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-base">terminal</span>
              <code>auto-message send "Deploy complete"</code>
            </div>
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-base">settings</span>
              <span class="font-body text-sm">Resolves token &amp; chat ID</span>
            </div>
          </div>
        </div>
        <!-- Connector -->
        <div class="hidden md:flex flex-col items-center justify-center text-surface-container-highest">
          <div class="h-full w-px bg-surface-container-highest"></div>
          <div class="bg-surface-container-lowest p-2 border border-surface-container-highest rounded-full my-4 flex items-center justify-center">
            <span class="material-symbols-outlined text-on-surface-variant leading-none">arrow_forward</span>
          </div>
          <div class="h-full w-px bg-surface-container-highest"></div>
        </div>
        <!-- Output -->
        <div class="flex-1">
          <h4 class="font-headline font-bold text-on-surface mb-6 border-b border-surface-container-highest pb-2">Telegram Chat</h4>
          <div class="space-y-3 font-mono text-sm text-on-surface-variant">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-base">cloud</span>
              <span class="font-body text-sm">HTTPS POST to Bot API</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-base">chat</span>
              <span class="font-body text-sm">Notification delivered</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Configuration -->
  <section class="py-32 px-8 bg-surface" id="setup">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-headline font-bold mb-6 text-on-surface tracking-tight">
        Simple Configuration
      </h2>
      <p class="font-body text-lg text-on-surface-variant mb-12">
        Profiles are stored at <code class="font-mono text-sm bg-surface-container px-1.5 py-0.5">~/.config/auto-message/config.json</code>
      </p>
      <div class="bg-surface-container-low p-8 border border-outline-variant/15 text-left inline-block w-full max-w-2xl">
        <pre class="font-mono text-sm text-on-surface overflow-x-auto"><code set:html={configJson} /></pre>
      </div>
    </div>
  </section>

  <!-- Copy Button Script -->
  <script>
    document.getElementById("hero-copy-btn")?.addEventListener("click", async (e) => {
      const btn = e.currentTarget as HTMLElement;
      const code = `curl -fsSL https://raw.githubusercontent.com/onurkerem/auto-message/main/install.sh | sh`;
      await navigator.clipboard.writeText(code);
      const icon = btn.querySelector(".material-symbols-outlined");
      if (icon) {
        icon.textContent = "check";
        setTimeout(() => { icon.textContent = "content_copy"; }, 2000);
      }
    });
  </script>
</Layout>
